# Forex for Soul — Environment Variables
# perpetual fx on devnet — never wire mainnet keys here

# anchor cli
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# rpc — helius for stable devnet throughput
HELIUS_API_KEY=

# pyth price feeds (Hermes)
PYTH_HERMES_URL=https://hermes.pyth.network

# frontend (next.js)
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_PROGRAM_ID=

# crank — price-push + funding-rate jobs
CRANK_KEYPAIR_PATH=./crank-keypair.json
# how often the price-push crank ticks (milliseconds)
PRICE_UPDATE_INTERVAL_MS=2000
# funding rate accrual cadence (seconds)
FUNDING_INTERVAL_SECONDS=3600
