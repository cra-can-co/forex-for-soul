{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["scripts/**/*.ts"]
}
